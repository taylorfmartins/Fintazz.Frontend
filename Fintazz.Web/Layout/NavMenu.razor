<AuthorizeView>
    <Authorized>
        <MudNavMenu>
            <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Rounded.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/grupos" Icon="@Icons.Material.Rounded.Groups">
                Grupos Familiares
            </MudNavLink>
            <MudDivider Class="my-1" />
            <MudNavLink Href="/contas-bancarias" Icon="@Icons.Material.Rounded.AccountBalance">
                Contas Bancárias
            </MudNavLink>
            <MudNavLink Href="/cartoes-credito" Icon="@Icons.Material.Rounded.CreditCard">
                Cartões de Crédito
            </MudNavLink>
            <MudNavLink Href="/transacoes" Icon="@Icons.Material.Rounded.SwapHoriz">
                Transações
            </MudNavLink>
            <MudNavLink Href="/transacoes-recorrentes" Icon="@Icons.Material.Rounded.Repeat">
                Recorrentes
            </MudNavLink>
            <MudNavLink Href="/categorias" Icon="@Icons.Material.Rounded.Category">
                Categorias
            </MudNavLink>

            <AuthorizeView Roles="admin">
                <MudDivider Class="my-1" />
                <MudNavLink Href="/admin" Icon="@Icons.Material.Rounded.AdminPanelSettings" IconColor="Color.Warning">
                    Admin
                </MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </Authorized>
</AuthorizeView>
