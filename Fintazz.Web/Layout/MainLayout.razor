@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="_darkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Dense="false">
                <MudIconButton Icon="@Icons.Material.Rounded.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <img src="icon-192.png" alt="Fintazz" style="height:32px;width:32px;margin-left:8px;" />
                @if (AppState.HasHouseHold)
                {
                    <MudChip T="string" Icon="@Icons.Material.Rounded.Groups" Size="Size.Small"
                             Color="Color.Primary" Class="ml-2 d-none d-sm-flex">
                        @AppState.HouseHoldName
                    </MudChip>
                }
                <MudSpacer />
                <MudTooltip Text="@(_darkMode ? "Modo claro" : "Modo escuro")">
                    <MudIconButton Icon="@(_darkMode ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)"
                                   Color="Color.Inherit" OnClick="ToggleTheme" />
                </MudTooltip>
                <MudTooltip Text="Sair">
                    <MudIconButton Icon="@Icons.Material.Rounded.Logout" Color="Color.Inherit"
                                   OnClick="@Logout" />
                </MudTooltip>
            </MudAppBar>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
                       Variant="DrawerVariant.Responsive">
                <MudDrawerHeader>
                    <div class="d-flex align-center gap-2">
                        <img src="icon-192.png" alt="Fintazz" style="height:36px;width:36px;" />
                        <MudText Typo="Typo.h6" Class="fw-bold">Fintazz</MudText>
                    </div>
                </MudDrawerHeader>
                <NavMenu />
            </MudDrawer>
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-md-6">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center align-center" Style="min-height:100vh">
            @Body
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;
    private bool _darkMode = true;

    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private TokenStorageService TokenStorage { get; set; } = default!;
    [Inject] private FintazzAuthStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private AppState AppState { get; set; } = default!;

    private readonly MudTheme _theme = new()
    {
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Inter", "Roboto", "sans-serif"]
            }
        },
        PaletteLight = new PaletteLight
        {
            Primary = "#6C63FF",
            PrimaryDarken = "#5A52E0",
            PrimaryLighten = "#8B84FF",
            Secondary = "#FF6584",
            Tertiary = "#43D9AD",
            Background = "#F8F9FC",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1A1A2E",
            TextPrimary = "#1A1A2E",
            TextSecondary = "#6B7280",
            ActionDefault = "#6B7280",
            DividerLight = "#E5E7EB",
            OverlayLight = "rgba(255,255,255,0.7)"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#7C74FF",
            PrimaryDarken = "#6C63FF",
            PrimaryLighten = "#9D97FF",
            Secondary = "#FF6584",
            Tertiary = "#43D9AD",
            Background = "#0F0F1A",
            Surface = "#1A1A2E",
            DrawerBackground = "#131320",
            AppbarBackground = "#13132026",
            AppbarText = "#E5E7EB",
            TextPrimary = "#E5E7EB",
            TextSecondary = "#9CA3AF",
            ActionDefault = "#9CA3AF",
            DividerLight = "#2D2D45"
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "fintazz_darkmode");
            _darkMode = saved != "false";

            var hhId = await JS.InvokeAsync<string?>("localStorage.getItem", "fintazz_household_id");
            var hhName = await JS.InvokeAsync<string?>("localStorage.getItem", "fintazz_household_name");
            if (Guid.TryParse(hhId, out var id) && !string.IsNullOrWhiteSpace(hhName))
                AppState.SetHouseHold(id, hhName);

            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _darkMode = !_darkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "fintazz_darkmode", _darkMode.ToString().ToLower());
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await TokenStorage.ClearAsync();
        AppState.Clear();
        await JS.InvokeVoidAsync("localStorage.removeItem", "fintazz_household_id");
        await JS.InvokeVoidAsync("localStorage.removeItem", "fintazz_household_name");
        AuthStateProvider.NotifyUserLoggedOut();
        Navigation.NavigateTo("/");
    }
}
